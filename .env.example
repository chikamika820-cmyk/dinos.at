# ─────────────────────────────────────────────────────────────
# Tripadvisor Content API  (https://www.tripadvisor.com/developers)
# Copy to .env.local for local dev, and set the same keys in
# Vercel → Project → Settings → Environment Variables for production.
# Never commit real values — .env.local is git-ignored.
# ─────────────────────────────────────────────────────────────

# Your Tripadvisor Content API key (required to load live reviews).
TRIPADVISOR_API_KEY=

# Location id of Dino's Apothecary Bar on Tripadvisor.
# Already known from the profile URL; override here if needed.
TRIPADVISOR_LOCATION_ID=6210796
